#!/bin/bash
# ASCII pet launcher - alacritty with true transparent background

i3-msg -q "[class=\"ascii-pet\"]" kill 2>/dev/null
sleep 0.3

# Launch alacritty with transparent background config
i3-msg 'exec --no-startup-id alacritty --class "ascii-pet" --config-file ~/.config/alacritty/pet.toml -e python3 /home/forest/.local/bin/ascii-pet'
