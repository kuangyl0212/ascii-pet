def roll_rarity(rng):
    total = sum(RARITY_WEIGHTS.values()); roll = rng() * total
    for r in RARITIES:
        roll -= RARITY_WEIGHTS[r]
        if roll < 0: return r
    return 'common'

def roll_stats(rng, rarity):
    floor = RARITY_FLOOR[rarity]; peak = pick(rng, STAT_NAMES); dump = pick(rng, STAT_NAMES)
    while dump == peak: dump = pick(rng, STAT_NAMES)
    stats = {}
    for n in STAT_NAMES:
        if n == peak: stats[n] = min(100, floor + 50 + int(rng()*30))
        elif n == dump: stats[n] = max(1, floor - 10 + int(rng()*15))
        else: stats[n] = floor + int(rng()*40)
    return stats

def generate_companion(uid, seed=None):
    if seed is None: seed = str(time.time_ns())
    rng = mulberry32(hash_string(uid + SALT + seed)); rarity = roll_rarity(rng)
    return {'rarity':rarity,'species':pick(rng,SPECIES),'eye':pick(rng,EYES),
            'hat':'none' if rarity=='common' else pick(rng,list(HAT_LINES.keys())),
            'shiny':rng()<0.01,'stats':roll_stats(rng,rarity)}

def generate_name(uid, seed=None):
    if seed is None: seed = str(time.time_ns())
    rng = mulberry32(hash_string(uid + SALT + seed + '-name'))
    return pick(rng, ADJECTIVES) + ' ' + pick(rng, NOUNS)

def render_sprite(bones, frame=0):
    frames = BODIES[bones['species']]
    body = [l.replace('{E}', bones['eye']) for l in frames[frame % len(frames)]]
    if bones['hat'] != 'none' and not body[0].strip(): body[0] = HAT_LINES[bones['hat']]
    if not body[0].strip() and all(not f[0].strip() for f in frames): body.pop(0)
    return body

def render_face(bones):
    e = bones['eye']
    faces = {'duck':f'({e}>','goose':f'({e}>','blob':f'({e}{e})','cat':f'={e}ω{e}=',
        'dragon':f'<{e}~{e}>','octopus':f'~({e}{e})~','owl':f'({e})({e})',
        'penguin':f'({e}>)','turtle':f'[{e}_{e}]','snail':f'{e}(@)',
        'ghost':f'/{e}{e}\\','axolotl':f'}}{e}.{e}{{','capybara':f'({e}oo{e})',
        'cactus':f'|{e}  {e}|','robot':f'[{e}{e}]','rabbit':f'({e}..{e})',
        'mushroom':f'|{e}  {e}|','chonk':f'({e}.{e})'}
    return faces.get(bones['species'], f'({e}{e})')

def stat_bar(value, width=15):
    filled = round((value / 100) * width)
    return '\033[90m\033[32m' + '█'*filled + '\033[90m' + '░'*(width-filled) + '\033[0m'

DATA_DIR = Path.home() / '.local' / 'share' / 'ascii-pet'
def get_state_path(uid):
    DATA_DIR.mkdir(parents=True, exist_ok=True)
    return DATA_DIR / f'{hash_string(uid) & 0xFFFFFFFF:08x}.json'
def load_pets(uid):
    p = get_state_path(uid)
    if not p.exists(): return None
    data = json.load(open(p))
    if isinstance(data, list): return {'pets': data, 'current': 0}
    if 'pets' not in data: return {'pets': [data], 'current': 0}
    return data
def save_pets(uid, data):
    json.dump(data, open(get_state_path(uid), 'w'), indent=2)
def load_state(uid):
    data = load_pets(uid)
    if data is None: return None, None, 0
    idx = data.get('current', 0)
    if idx >= len(data['pets']): idx = 0
    return data['pets'][idx], data, idx
def save_state(uid, state, pets_data, idx):
    pets_data['pets'][idx] = state
    save_pets(uid, pets_data)
def init_state(uid, bones, name):
    now = datetime.now().isoformat()
    return {'user_id':uid,'name':name,'species':bones['species'],'rarity':bones['rarity'],
            'eye':bones['eye'],'hat':bones['hat'],'shiny':bones['shiny'],'stats':bones['stats'],
            'mood':'normal','created_at':now,'last_fed':now,'last_played':now,'last_slept':now,
            'level':1,'xp':0,'total_interactions':0}

def update_state_over_time(state):
    now = datetime.now()
    for key, decay, rate in [('last_fed',4,5),('last_played',2,3),('last_slept',6,4)]:
        hours = (now - datetime.fromisoformat(state[key])).total_seconds() / 3600
        if hours > decay:
            stat = {'last_fed':'HUNGER','last_played':'HAPPY','last_slept':'ENERGY'}[key]
            state['stats'][stat] = max(0, state['stats'][stat] - int(hours * rate))
    h, e, p = state['stats']['HUNGER'], state['stats']['ENERGY'], state['stats']['HAPPY']
    state['mood'] = 'hungry' if h<20 else 'sleepy' if e<20 else 'excited' if p>80 else 'happy' if p>50 else 'normal'
    return state

# ─── Window control via xdotool ───────────────────────────────────────────────
FONT_W = 8   # approximate char width for monospace 11pt
FONT_H = 17  # approximate char height for monospace 11pt

def get_win_id():
    for _ in range(5):
        try:
            out = subprocess.check_output(['xdotool','search','--class','ascii-pet'], timeout=2).decode().strip()
            if out: return out.split('\n')[0]
        except: pass
        time.sleep(0.2)
    return None

def set_window_geometry(cols, rows, pos_x, pos_y):
    wid = get_win_id()
    if not wid: return
    px_w = cols * FONT_W + 20
    px_h = rows * FONT_H + 10
    try:
        subprocess.run(['xdotool','windowsize',wid,str(px_w),str(px_h)], timeout=2)
        subprocess.run(['xdotool','windowmove',wid,str(pos_x),str(pos_y)], timeout=2)
    except: pass

def set_window_opacity(wid, opacity_hex):
    if not wid: return
    try:
        subprocess.run(['xprop','-id',wid,'-f','_NET_WM_WINDOW_OPACITY','32c','-set','_NET_WM_WINDOW_OPACITY',opacity_hex], timeout=2)
    except: pass

def get_screen_size():
    try:
        out = subprocess.check_output(['xdotool','getdisplaygeometry'], timeout=2).decode().strip().split()
        return int(out[0]), int(out[1])
    except: return 1920, 1080

# ─── Terminal ──────────────────────────────────────────────────────────────────
def clear_screen(): sys.stdout.write('\033[2J\033[H'); sys.stdout.flush()
def move_cursor_top(): sys.stdout.write('\033[H'); sys.stdout.flush()
def hide_cursor(): sys.stdout.write('\033[?25l'); sys.stdout.flush()
def show_cursor(): sys.stdout.write('\033[?25h'); sys.stdout.flush()
def get_key():
    fd = sys.stdin.fileno()
    try: old = termios.tcgetattr(fd)
    except: return None
    try:
        tty.setraw(fd)
        dr,_,_ = select.select([sys.stdin],[],[],0.1)
        return sys.stdin.read(1) if dr else None
    finally:
        try: termios.tcsetattr(fd, termios.TCSADRAIN, old)
        except: pass

# ─── Display ───────────────────────────────────────────────────────────────────
def render_frame(bones, frame_idx):
    step = IDLE_SEQUENCE[frame_idx % len(IDLE_SEQUENCE)]
    if step == -1:
        f = render_sprite(bones, 0)
        return [l.replace(bones['eye'], '-') for l in f]
    return render_sprite(bones, step)

def build_compact(bones, frame_idx, state):
    lines = render_frame(bones, frame_idx)
    return '\n'.join(lines)

def build_expanded(state, bones, frame_idx, show_help=False):
    RST='\033[0m'; DIM='\033[2m'; BOLD='\033[1m'
    color = RARITY_COLORS[state['rarity']]; stars = RARITY_STARS[state['rarity']]
    shiny = f' {BOLD}\033[33mSHINY{RST}' if state['shiny'] else ''
    mood = MOODS[state['mood']]
    frame = render_frame(bones, frame_idx)

    lines = []
    lines.append(f'{color}{BOLD}{state["name"]}{RST} {color}{stars}{RST}{shiny}')
    lines.append(f'{DIM}{state["species"]}·{state["rarity"]}{RST} {mood["color"]}[{mood["emoji"]}]{RST}')
    lines.append(f'{DIM}Lv.{state["level"]} XP:{state["xp"]}/{state["level"]*100}{RST}')
    for row in frame: lines.append(f' {row}')
    lines.append(f'{DIM}face:{render_face(bones)}{RST}')
    for s in STAT_NAMES:
        v = state['stats'][s]
        lines.append(f'{DIM}{s[:4]}{RST}{stat_bar(v,15)}{v}')
    if show_help:
        lines.append(f'{DIM}[f]feed [p]play [s]sleep [r]reset [b]prev [n]next [Enter]compact [q]quit{RST}')
    else:
        lines.append(f'{DIM}[?]help [b]prev [n]next [Enter]compact [q]quit{RST}')
    return '\n'.join(lines)

def build_info(state, bones, frame_idx, pet_idx=0, pet_count=1):
    RST='\033[0m'; DIM='\033[2m'; BOLD='\033[1m'
    color = RARITY_COLORS[state['rarity']]; stars = RARITY_STARS[state['rarity']]
    shiny = f' SHINY' if state['shiny'] else ''
    frame = render_frame(bones, frame_idx)

    lines = [f'{BOLD}{state["name"]}{RST}{shiny} {color}{stars}{RST}']
    lines.append(f'{state["species"]}·{state["rarity"]} Eye:{state["eye"]} Hat:{state["hat"]} Lv.{state["level"]}')
    lines.append(f'Interactions:{state["total_interactions"]} Pet:{pet_idx+1}/{pet_count}')
    for row in frame: lines.append(f' {row}')
    for s in STAT_NAMES:
        v = state['stats'][s]
        lines.append(f'{DIM}{s[:4]}{RST}{stat_bar(v,15)}{v}')
    lines.append(f'{DIM}[i]back [q]quit{RST}')
    return '\n'.join(lines)

# ─── Actions ───────────────────────────────────────────────────────────────────
def feed_pet(state):
    if state['stats']['HUNGER'] >= 100: return 'Already full!'
    state['stats']['HUNGER'] = min(100, state['stats']['HUNGER']+25)
    state['stats']['HAPPY'] = min(100, state['stats']['HAPPY']+5)
    state['last_fed'] = datetime.now().isoformat()
    state['total_interactions'] += 1; state['xp'] += 10; check_level_up(state)
    return '+25 Hunger, +5 Happy'

def play_pet(state):
    if state['stats']['ENERGY'] < 10: return 'Too tired!'
    state['stats']['HAPPY'] = min(100, state['stats']['HAPPY']+30)
    state['stats']['ENERGY'] = max(0, state['stats']['ENERGY']-15)
    state['stats']['HUNGER'] = max(0, state['stats']['HUNGER']-10)
    state['last_played'] = datetime.now().isoformat()
    state['total_interactions'] += 1; state['xp'] += 15; check_level_up(state)
    return '+30 Happy, -15 Energy'

def sleep_pet(state):
    if state['stats']['ENERGY'] >= 100: return 'Not sleepy!'
    state['stats']['ENERGY'] = min(100, state['stats']['ENERGY']+40)
    state['stats']['HUNGER'] = max(0, state['stats']['HUNGER']-5)
    state['last_slept'] = datetime.now().isoformat()
    state['total_interactions'] += 1; state['xp'] += 5; check_level_up(state)
    return '+40 Energy'

def check_level_up(state):
    xp_need = state['level'] * 100
    while state['xp'] >= xp_need:
        state['xp'] -= xp_need; state['level'] += 1
        state['stats']['WISDOM'] = min(100, state['stats']['WISDOM']+5)
        xp_need = state['level'] * 100

# ─── Window layout ─────────────────────────────────────────────────────────────
STATUS_BAR_HEIGHT = 30

def layout_compact():
    sw, sh = get_screen_size()
    cols, rows = 18, 8
    px_w = cols * FONT_W + 8
    px_h = rows * FONT_H + 4
    px = sw - px_w - 10
    py = sh - px_h - STATUS_BAR_HEIGHT
    set_window_geometry(cols, rows, px, py)

def layout_expanded():
    sw, sh = get_screen_size()
    cols, rows = 50, 24
    px_w = cols * FONT_W + 20
    px_h = rows * FONT_H + 10
    px = sw - px_w - 20
    py = sh - px_h - STATUS_BAR_HEIGHT
    set_window_geometry(cols, rows, px, py)

def layout_info():
    sw, sh = get_screen_size()
    cols, rows = 42, 18
    px_w = cols * FONT_W + 20
    px_h = rows * FONT_H + 10
    px = sw - px_w - 20
    py = sh - px_h - STATUS_BAR_HEIGHT
    set_window_geometry(cols, rows, px, py)

# ─── Main ──────────────────────────────────────────────────────────────────────
def main():
    uid = os.environ.get('USER', os.environ.get('USERNAME', 'anon'))
    if len(sys.argv) > 1:
        arg = sys.argv[1]
        if arg in ('--help','-h'):
            print('  ascii-pet — Terminal companion pet\n\n  Usage:\n    ascii-pet              Start pet\n    ascii-pet [username]   Specific username\n    ascii-pet --all        Show all species\n    ascii-pet --help       Help\n\n  Compact mode: just the pet\n  Expanded mode: full stats (Enter to toggle)\n  Info mode: detailed info (i to toggle)\n  Commands: f feed, p play, s sleep, r reset, b prev, n next, q quit')
            sys.exit(0)
        if arg == '--all':
            print('\n  All 18 species:\n')
            for sp in SPECIES:
                fb = {'species':sp,'eye':'·','hat':'none','shiny':False,'stats':{},'rarity':'common'}
                print(f'  {sp}  {render_face(fb)}')
                for row in render_sprite(fb, 0): print(f'  {row}')
                print()
            sys.exit(0)
        uid = arg

    state, pets_data, pet_idx = load_state(uid)
    if state is None:
        bones = generate_companion(uid); name = generate_name(uid)
        state = init_state(uid, bones, name)
        pets_data = {'pets': [state], 'current': 0}; pet_idx = 0
        save_pets(uid, pets_data)
    else:
        bones = {k: state[k] for k in ('species','eye','hat','shiny','rarity')}

    state = update_state_over_time(state); save_state(uid, state, pets_data, pet_idx)
    signal.signal(signal.SIGINT, lambda *_: (show_cursor(), clear_screen(), sys.exit(0)))

    clear_screen(); hide_cursor()

    frame_idx = 0; mode = 'compact'  # compact / expanded / info
    show_help = False; last_tick = time.time(); message = None; message_time = 0
    layout_compact()

    prev_display = None; prev_mode = None; need_redraw = True

    try:
        while True:
            now = time.time()
            if now - last_tick >= 0.5:
                frame_idx += 1; state = update_state_over_time(state)
                save_state(uid, state, pets_data, pet_idx); last_tick = now
                need_redraw = True

            if mode != prev_mode:
                if mode == 'compact': layout_compact()
                elif mode == 'expanded': layout_expanded()
                else: layout_info()
                prev_mode = mode; need_redraw = True
                time.sleep(0.15)  # let window resize settle

            if need_redraw:
                if mode == 'compact':
                    display = build_compact(bones, frame_idx, state)
                elif mode == 'expanded':
                    display = build_expanded(state, bones, frame_idx, show_help)
                else:
                    display = build_info(state, bones, frame_idx, pet_idx, len(pets_data['pets']))
                if message and time.time() - message_time < 2:
                    display += f'\n  \033[33m{message}\033[0m'

                if display != prev_display:
                    clear_screen()
                    print(display, end='', flush=True)
                    prev_display = display
                need_redraw = False

            key = get_key()
            if key == 'q': break
            elif key in ('\r','\n'):
                if mode == 'compact':
                    mode = 'expanded'; show_help = False
                elif mode == 'expanded':
                    mode = 'compact'; show_help = False
                elif mode == 'info':
                    mode = 'expanded'; show_help = False
            elif key == '?':
                if mode == 'compact':
                    mode = 'expanded'; show_help = True
                else:
                    show_help = not show_help; need_redraw = True
            elif key == 'esc':
                if mode != 'compact':
                    mode = 'compact'; show_help = False
            elif key == 'b':
                if len(pets_data['pets']) > 1:
                    pets_data['pets'][pet_idx] = state
                    pet_idx = (pet_idx - 1) % len(pets_data['pets'])
                    state = pets_data['pets'][pet_idx]
                    bones = {k: state[k] for k in ('species','eye','hat','shiny','rarity')}
                    pets_data['current'] = pet_idx; save_pets(uid, pets_data)
                    message = f'Switched to {state["name"]}'; message_time = time.time()
                    need_redraw = True
            elif key == 'n':
                pets_data['pets'][pet_idx] = state
                if pet_idx < len(pets_data['pets']) - 1:
                    pet_idx += 1
                else:
                    new_state = init_state(uid, generate_companion(uid), generate_name(uid))
                    pets_data['pets'].append(new_state)
                    pet_idx = len(pets_data['pets']) - 1
                state = pets_data['pets'][pet_idx]
                bones = {k: state[k] for k in ('species','eye','hat','shiny','rarity')}
                pets_data['current'] = pet_idx; save_pets(uid, pets_data)
                message = f'Switched to {state["name"]}'; message_time = time.time()
                need_redraw = True
            elif key == 'i':
                if mode == 'info':
                    mode = 'expanded'
                elif mode == 'expanded':
                    mode = 'info'
                else:
                    mode = 'info'
            elif key == 'f' and mode != 'compact':
                message = feed_pet(state); message_time = time.time()
                save_state(uid, state, pets_data, pet_idx); need_redraw = True
            elif key == 'p' and mode != 'compact':
                message = play_pet(state); message_time = time.time()
                save_state(uid, state, pets_data, pet_idx); need_redraw = True
            elif key == 's' and mode != 'compact':
                message = sleep_pet(state); message_time = time.time()
                save_state(uid, state, pets_data, pet_idx); need_redraw = True
            elif key == 'r' and mode != 'compact':
                bones = generate_companion(uid); name = generate_name(uid)
                state = init_state(uid, bones, name)
                pets_data['pets'][pet_idx] = state; save_pets(uid, pets_data)
                message = 'Regenerated!'; message_time = time.time()
                need_redraw = True
            elif key == 'n' and mode != 'compact':
                bones = generate_companion(uid); name = generate_name(uid)
                new_state = init_state(uid, bones, name)
                pets_data['pets'].append(new_state)
                pet_idx = len(pets_data['pets']) - 1
                state = new_state; pets_data['current'] = pet_idx
                save_pets(uid, pets_data)
                message = f'New pet: {name}'; message_time = time.time()
                need_redraw = True
    finally:
        show_cursor(); clear_screen()
        print(f'\n  {render_face(bones)}  Bye!\n')

if __name__ == '__main__': main()
