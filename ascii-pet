#!/usr/bin/env python3
"""ASCII Desktop Pet - Terminal Companion (Linux)"""

import os, sys, signal, subprocess, select, time
if sys.platform == 'win32':
    import msvcrt, ctypes
else:
    import termios, tty

from pet_core import (
    SPECIES, RARITY_STARS, STAT_NAMES, MOODS, ANIMATIONS, ACHIEVEMENTS, MAX_PETS,
    render_sprite, render_face, render_frame, export_text,
    PetGame,
)

# ─── ANSI colors ──────────────────────────────────────────────────────────────

RARITY_COLORS = {'common':'\033[90m','uncommon':'\033[32m','rare':'\033[36m','epic':'\033[35m','legendary':'\033[33m'}
MOOD_COLORS = {'happy':'\033[33m','normal':'\033[0m','sleepy':'\033[90m','hungry':'\033[31m','excited':'\033[35m'}

# ─── Window control via xdotool ───────────────────────────────────────────────

FONT_W = 8
FONT_H = 17
STATUS_BAR_HEIGHT = 30
_window_pos = None

def get_win_id():
    if sys.platform == 'win32':
        return ctypes.windll.kernel32.GetConsoleWindow()
    for _ in range(5):
        try:
            out = subprocess.check_output(['xdotool','search','--class','ascii-pet'], timeout=2).decode().strip()
            if out: return out.split('\n')[0]
        except: pass
        time.sleep(0.2)
    return None

def set_window_geometry(cols, rows, pos_x, pos_y):
    if sys.platform == 'win32':
        hwnd = ctypes.windll.kernel32.GetConsoleWindow()
        if not hwnd: return
        px_w = cols * FONT_W + 20
        px_h = rows * FONT_H + 10
        ctypes.windll.user32.MoveWindow(hwnd, pos_x, pos_y, px_w, px_h, True)
        return
    wid = get_win_id()
    if not wid: return
    px_w = cols * FONT_W + 20
    px_h = rows * FONT_H + 10
    try:
        subprocess.run(['xdotool','windowsize',wid,str(px_w),str(px_h)], timeout=2)
        subprocess.run(['xdotool','windowmove',wid,str(pos_x),str(pos_y)], timeout=2)
    except: pass

def get_screen_size():
    if sys.platform == 'win32':
        user32 = ctypes.windll.user32
        return user32.GetSystemMetrics(0), user32.GetSystemMetrics(1)
    try:
        out = subprocess.check_output(['xdotool','getdisplaygeometry'], timeout=2).decode().strip().split()
        return int(out[0]), int(out[1])
    except: return 1920, 1080

def get_window_pos():
    if sys.platform == 'win32':
        hwnd = ctypes.windll.kernel32.GetConsoleWindow()
        if not hwnd: return None
        from ctypes import wintypes, byref
        rect = wintypes.RECT()
        ctypes.windll.user32.GetWindowRect(hwnd, byref(rect))
        return rect.left, rect.top
    wid = get_win_id()
    if not wid: return None
    try:
        out = subprocess.check_output(['xdotool', 'getwindowgeometry', '--shell', wid], timeout=2).decode().strip()
        x, y = None, None
        for line in out.splitlines():
            if line.startswith('X='): x = int(line.split('=')[1])
            elif line.startswith('Y='): y = int(line.split('=')[1])
        if x is not None and y is not None: return x, y
    except: pass
    return None

def _clamp_pos(px, py, pw, ph, sw, sh):
    return max(0, min(px, sw - pw)), max(0, min(py, sh - ph))

# ─── Terminal ─────────────────────────────────────────────────────────────────

def clear_screen(): sys.stdout.write('\033[2J\033[H'); sys.stdout.flush()
def hide_cursor(): sys.stdout.write('\033[?25l'); sys.stdout.flush()
def show_cursor(): sys.stdout.write('\033[?25h'); sys.stdout.flush()

def get_key():
    if sys.platform == 'win32':
        if msvcrt.kbhit():
            b = msvcrt.getch()
            try: return b.decode('utf-8', errors='replace')
            except: return None
        return None
    fd = sys.stdin.fileno()
    try: old = termios.tcgetattr(fd)
    except: return None
    try:
        tty.setraw(fd)
        dr,_,_ = select.select([sys.stdin],[],[],0.1)
        return sys.stdin.read(1) if dr else None
    finally:
        try: termios.tcsetattr(fd, termios.TCSADRAIN, old)
        except: pass

# ─── ANSI rendering ───────────────────────────────────────────────────────────

def stat_bar(value, width=15):
    filled = round((value / 100) * width)
    return '\033[90m\033[32m' + '█'*filled + '\033[90m' + '░'*(width-filled) + '\033[0m'

def build_compact(game):
    lines = render_frame(game.bones, game.frame_idx, game.state.get('mood','normal'))
    return '\n'.join(lines)

def build_expanded(game):
    RST='\033[0m'; DIM='\033[2m'; BOLD='\033[1m'
    color = RARITY_COLORS[game.state['rarity']]; stars = RARITY_STARS[game.state['rarity']]
    shiny = f' {BOLD}\033[33mSHINY{RST}' if game.state['shiny'] else ''
    mood = MOODS[game.state['mood']]
    frame = render_frame(game.bones, game.frame_idx, game.state.get('mood','normal'))

    lines = []
    lines.append(f'{color}{BOLD}{game.state["name"]}{RST} {color}{stars}{RST}{shiny}')
    lines.append(f'{DIM}{game.state["species"]}·{game.state["rarity"]}{RST} {MOOD_COLORS[game.state["mood"]]}[{mood["emoji"]}]{RST}')
    lines.append(f'{DIM}Lv.{game.state["level"]} XP:{game.state["xp"]}/{game.state["level"]*100}{RST}')
    if game.state.get('evolved'):
        lines.append(f'{DIM}★ Evolved{RST}')
    for row in frame: lines.append(f' {row}')
    for s in STAT_NAMES:
        v = game.state['stats'][s]
        lines.append(f'{DIM}{s[:4]}{RST}{stat_bar(v,15)}{v}')
    if game.show_help:
        lines.append(f'{DIM}[f]feed [p]play [s]sleep [w]adopt [b]prev [n]next [t]stats [a]achieve [e]export [m]move [Enter]compact [q]quit{RST}')
    return '\n'.join(lines)

def build_stats(game):
    RST='\033[0m'; DIM='\033[2m'; BOLD='\033[1m'
    color = RARITY_COLORS[game.state['rarity']]
    frame = render_frame(game.bones, game.frame_idx, game.state.get('mood','normal'))
    from datetime import datetime
    created = datetime.fromisoformat(game.state['created_at'])
    days = (datetime.now() - created).days
    hours = (datetime.now() - created).total_seconds() / 3600
    evo = ' ★Evolved' if game.state.get('evolved') else ''

    lines = [f'{BOLD}Stats for {game.state["name"]}{RST}']
    lines.append(f'{DIM}Species:{RST} {game.state["species"]}')
    lines.append(f'{DIM}Face:{RST} {render_face(game.bones)}')
    lines.append(f'{DIM}Eye:{RST} {game.state["eye"]}')
    lines.append(f'{DIM}Hat:{RST} {game.state["hat"]}')
    lines.append(f'{DIM}Pet:{RST} {game.pet_idx+1}/{len(game.pets_data["pets"])}{evo}')
    lines.append('')
    for row in frame: lines.append(f' {row}')
    lines.append('')
    lines.append(f'{DIM}--- Activity ---{RST}')
    lines.append(f'  {DIM}Days adopted:{RST}  {days}')
    lines.append(f'  {DIM}Hours online:{RST} {hours:.1f}')
    lines.append(f'  {DIM}Feed count:{RST}   {game.state.get("feed_count",0)}')
    lines.append(f'  {DIM}Play count:{RST}   {game.state.get("play_count",0)}')
    lines.append(f'  {DIM}Sleep count:{RST}  {game.state.get("sleep_count",0)}')
    lines.append(f'  {DIM}Total acts:{RST}   {game.state["total_interactions"]}')
    lines.append('')
    lines.append(f'{DIM}--- Growth ---{RST}')
    lines.append(f'  {DIM}Level:{RST} {game.state["level"]}  {DIM}XP:{RST} {game.state["xp"]}/{game.state["level"]*100}')
    lines.append(f'  {DIM}Rarity:{RST} {game.state["rarity"]}  {DIM}Shiny:{RST} {"Yes" if game.state["shiny"] else "No"}')
    return '\n'.join(lines)

def build_achievements(game):
    RST='\033[0m'; DIM='\033[2m'; BOLD='\033[1m'
    unlocked = game.state.get('achievements', [])
    lines = [f'{BOLD}Achievements for {game.state["name"]}{RST}']
    lines.append(f'{DIM}{len(unlocked)}/{len(ACHIEVEMENTS)} unlocked{RST}')
    lines.append('')
    for aid, ach in ACHIEVEMENTS.items():
        if aid in unlocked:
            lines.append(f'  {ach["icon"]} {BOLD}{ach["name"]}{RST}')
        else:
            lines.append(f'  {DIM}??? Locked{RST}')
    return '\n'.join(lines)

def build_release(game):
    RST='\033[0m'; DIM='\033[2m'; BOLD='\033[1m'
    pets = game.get_release_list()
    lines = [f'{BOLD}\033[31mSelect a pet to release:{RST}']
    lines.append(f'{DIM}Max {MAX_PETS} pets. Choose 1-3, or [c]cancel{RST}')
    lines.append('')
    for idx, name, species, rarity in pets:
        color = RARITY_COLORS[rarity]
        stars = RARITY_STARS[rarity]
        lines.append(f'  {BOLD}{idx}{RST}  {color}{name}{RST} {DIM}{species}·{rarity}{RST} {color}{stars}{RST}')
    lines.append('')
    lines.append(f'{DIM}[1-3]select [c]cancel{RST}')
    return '\n'.join(lines)

def build_death(game):
    RST='\033[0m'; BOLD='\033[1m'; RED='\033[31m'
    frame = render_frame(game.bones, game.frame_idx, 'normal')
    lines = [f'{RED}{BOLD}  Your pet has died...{RST}']
    lines.append('')
    for row in frame:
        lines.append(f'  \033[90m{row}{RST}')
    lines.append('')
    lines.append(f'{RED}  Press [f]feed, [p]play, or [s]sleep to revive{RST}')
    return '\n'.join(lines)

# ─── Layout ───────────────────────────────────────────────────────────────────

def layout_compact():
    global _window_pos
    sw, sh = get_screen_size()
    cols, rows = 18, 8
    px_w = cols * FONT_W + 8
    px_h = rows * FONT_H + 4
    if _window_pos:
        px, py = _clamp_pos(_window_pos[0], _window_pos[1], px_w, px_h, sw, sh)
    else:
        px = sw - px_w - 10
        py = sh - px_h - STATUS_BAR_HEIGHT
    set_window_geometry(cols, rows, px, py)

def layout_expanded():
    global _window_pos
    sw, sh = get_screen_size()
    cols, rows = 36, 26
    px_w = cols * FONT_W + 20
    px_h = rows * FONT_H + 10
    if _window_pos:
        px, py = _clamp_pos(_window_pos[0], _window_pos[1], px_w, px_h, sw, sh)
    else:
        px = sw - px_w - 20
        py = sh - px_h - STATUS_BAR_HEIGHT
    set_window_geometry(cols, rows, px, py)

