    global _window_pos
    sw, sh = get_screen_size()
    cols, rows = 42, 24
    px_w = cols * FONT_W + 20
    px_h = rows * FONT_H + 10
    if _window_pos:
        px, py = _clamp_pos(_window_pos[0], _window_pos[1], px_w, px_h, sw, sh)
