def export_pet(state, bones, frame_idx):
    RST='\033[0m'; BOLD='\033[1m'
    color = RARITY_COLORS[state['rarity']]; stars = RARITY_STARS[state['rarity']]
    frame = render_frame(bones, frame_idx, state.get('mood','normal'))
    lines = [f'{state["name"]}  {stars}', f'{state["species"]} · {state["rarity"]}', '']
    for row in frame: lines.append(row)
    lines.append('')
    lines.append(f'face: {render_face(bones)}')
    lines.append('')
    for s in STAT_NAMES:
        v = state['stats'][s]
        lines.append(f'{s[:4]}  {"█"*round(v/5)}{"░"*(20-round(v/5))} {v}')
    text = '\n'.join(lines)
    cmds = [['xclip','-selection','clipboard'],['xsel','--clipboard','--input']]
    if sys.platform == 'win32':
        cmds = [['clip.exe']]
    for cmd in cmds:
        try:
            p = subprocess.Popen(cmd, stdin=subprocess.PIPE)
            p.communicate(text.encode())
            return 'Copied to clipboard!'
        except: pass
    print(text)
    return 'Printed to terminal (no clipboard tool)'

# ─── Main ──────────────────────────────────────────────────────────────────────
def main():
    uid = os.environ.get('USER', os.environ.get('USERNAME', 'anon'))
    if len(sys.argv) > 1:
        arg = sys.argv[1]
        if arg in ('--help','-h'):
            print('  ascii-pet — Terminal companion pet\n\n  Usage:\n    ascii-pet              Start pet\n    ascii-pet [username]   Specific username\n    ascii-pet --all        Show all species\n    ascii-pet --help       Help\n\n  Compact mode: just the pet\n  Expanded mode: full stats (Enter to toggle)\n  Info mode: detailed info (i to toggle)\n  Commands: f feed, p play, s sleep, r reset, b prev, n next, t stats, a achieve, e export, h help, c compact, q quit')
            sys.exit(0)
        if arg == '--all':
            print('\n  All 18 species:\n')
            for sp in SPECIES:
                fb = {'species':sp,'eye':'·','hat':'none','shiny':False,'stats':{},'rarity':'common'}
                print(f'  {sp}  {render_face(fb)}')
                for row in render_sprite(fb, 0): print(f'  {row}')
                print()
            sys.exit(0)
        uid = arg

    if sys.platform == 'win32':
        kernel32 = ctypes.windll.kernel32
        handle = kernel32.GetStdHandle(-11)  # STD_OUTPUT_HANDLE
        mode = ctypes.c_uint32()
        if kernel32.GetConsoleMode(handle, ctypes.byref(mode)):
            mode.value |= 0x0004  # ENABLE_VIRTUAL_TERMINAL_PROCESSING
            kernel32.SetConsoleMode(handle, mode)

    state, pets_data, pet_idx = load_state(uid)
    if state is None:
        bones = generate_companion(uid); name = generate_name(uid)
        state = init_state(uid, bones, name)
        pets_data = {'pets': [state], 'current': 0}; pet_idx = 0
        save_pets(uid, pets_data)
    else:
        bones = {k: state[k] for k in ('species','eye','hat','shiny','rarity')}

    state = update_state_over_time(state); save_state(uid, state, pets_data, pet_idx)
    signal.signal(signal.SIGINT, lambda *_: (show_cursor(), clear_screen(), sys.exit(0)))

    clear_screen(); hide_cursor()

    frame_idx = 0; mode = 'compact'  # compact / expanded / info
    show_help = False; last_tick = time.time(); message = None; message_time = 0
    reminder_shown = False; last_event_time = 0; anim_end = 0
    anim_frames = []; anim_idx = 0
    layout_compact()

    prev_display = None; prev_mode = None; need_redraw = True

    try:
        while True:
            now = time.time()
            if now - last_tick >= 0.5:
                frame_idx += 1; state = update_state_over_time(state)
                save_state(uid, state, pets_data, pet_idx); last_tick = now
                need_redraw = True
                stats = state['stats']
                if stats['HUNGER'] < 10 and not reminder_shown:
                    message = 'Your pet is starving!'; message_time = now; reminder_shown = True
                elif stats['ENERGY'] < 10 and not reminder_shown:
                    message = 'Your pet is exhausted!'; message_time = now; reminder_shown = True
                elif stats['HAPPY'] < 10 and not reminder_shown:
                    message = 'Your pet is lonely!'; message_time = now; reminder_shown = True
                if stats['HUNGER'] >= 10 and stats['ENERGY'] >= 10 and stats['HAPPY'] >= 10:
                    reminder_shown = False
                if now - last_event_time > 60 and random.random() < 0.01:
                    evt = random.choice(RANDOM_EVENTS)
                    message = evt[1]; message_time = now; last_event_time = now
                    for k, v in evt[2].items():
                        if k == 'xp': state['xp'] += v; check_level_up(state)
                        elif k in state['stats']: state['stats'][k] = min(100, state['stats'][k] + v)

            if mode != prev_mode:
                if mode == 'compact': layout_compact()
                elif mode == 'expanded': layout_expanded()
                elif mode == 'stats': layout_stats()
                elif mode == 'achievements': layout_achievements()
                else: layout_info()
                prev_mode = mode; need_redraw = True
                time.sleep(0.15)  # let window resize settle

            if need_redraw:
                if mode == 'compact':
                    display = build_compact(bones, frame_idx, state)
                elif mode == 'expanded':
                    display = build_expanded(state, bones, frame_idx, show_help)
                elif mode == 'stats':
                    display = build_stats(state, bones, frame_idx, pet_idx, len(pets_data['pets']))
                elif mode == 'achievements':
                    display = build_achievements(state, bones)
                else:
                    display = build_info(state, bones, frame_idx, pet_idx, len(pets_data['pets']))
                if message and time.time() - message_time < 2:
                    display += f'\n  \033[33m{message}\033[0m'

                if display != prev_display:
                    clear_screen()
                    print(display, end='', flush=True)
                    prev_display = display
                need_redraw = False

            if anim_end and now < anim_end:
                anim_idx = int((now * 6) % len(anim_frames))
                sys.stdout.write(f'\033[H{len(display.splitlines())+1}\033[K')
                sys.stdout.write(f'  \033[33m{anim_frames[anim_idx]}\033[0m\n')
                sys.stdout.flush()
            elif anim_end and now >= anim_end:
                anim_end = 0; need_redraw = True

            key = get_key()
            if key == 'q': break
            elif key in ('\r','\n'):
                if mode == 'compact':
                    mode = 'expanded'; show_help = False
                elif mode == 'expanded':
                    mode = 'compact'; show_help = False
                elif mode == 'info':
                    mode = 'expanded'; show_help = False
            elif key == 'h':
                if mode == 'compact':
                    mode = 'expanded'; show_help = True
                else:
                    show_help = not show_help; need_redraw = True
            elif key == 'c':
                if mode != 'compact':
                    mode = 'compact'; show_help = False
            elif key == 'b':
                if len(pets_data['pets']) > 1:
                    pets_data['pets'][pet_idx] = state
                    pet_idx = (pet_idx - 1) % len(pets_data['pets'])
                    state = pets_data['pets'][pet_idx]
                    bones = {k: state[k] for k in ('species','eye','hat','shiny','rarity')}
                    pets_data['current'] = pet_idx; save_pets(uid, pets_data)
                    new_ach = check_achievements(state, pets_data)
                    message = f'Switched to {state["name"]}'
                    if new_ach: message = f'Achievement: {new_ach[0]}!'
                    message_time = time.time()
                    need_redraw = True
            elif key == 'n':
                pets_data['pets'][pet_idx] = state
                if pet_idx < len(pets_data['pets']) - 1:
                    pet_idx += 1
                else:
                    new_state = init_state(uid, generate_companion(uid), generate_name(uid))
                    pets_data['pets'].append(new_state)
                    pet_idx = len(pets_data['pets']) - 1
                state = pets_data['pets'][pet_idx]
                bones = {k: state[k] for k in ('species','eye','hat','shiny','rarity')}
                pets_data['current'] = pet_idx; save_pets(uid, pets_data)
                new_ach = check_achievements(state, pets_data)
                message = f'Switched to {state["name"]}'
                if new_ach: message = f'Achievement: {new_ach[0]}!'
                message_time = time.time()
                need_redraw = True
            elif key == 'i':
                if mode == 'info':
                    mode = 'expanded'
                elif mode == 'expanded':
                    mode = 'info'
                else:
                    mode = 'info'
            elif key == 't':
                if mode == 'stats':
                    mode = 'expanded'
                elif mode in ('expanded', 'info'):
                    mode = 'stats'
                else:
                    mode = 'stats'
            elif key == 'a':
                if mode == 'achievements':
                    mode = 'expanded'
                elif mode in ('expanded', 'info', 'stats'):
                    mode = 'achievements'
                else:
                    mode = 'achievements'
            elif key == 'e' and mode != 'compact':
                message = export_pet(state, bones, frame_idx); message_time = time.time()
                need_redraw = True
            elif key == 'f' and mode != 'compact':
                message, anim_type = feed_pet(state); message_time = time.time()
                if anim_type: anim_end = now + 1.5; anim_frames = ANIMATIONS[anim_type]; anim_idx = 0
                new_ach = check_achievements(state, pets_data)
                if new_ach: message = f'Achievement: {new_ach[0]}!'; message_time = time.time()
                save_state(uid, state, pets_data, pet_idx); need_redraw = True
            elif key == 'p' and mode != 'compact':
                message, anim_type = play_pet(state); message_time = time.time()
                if anim_type: anim_end = now + 1.5; anim_frames = ANIMATIONS[anim_type]; anim_idx = 0
                new_ach = check_achievements(state, pets_data)
                if new_ach: message = f'Achievement: {new_ach[0]}!'; message_time = time.time()
                save_state(uid, state, pets_data, pet_idx); need_redraw = True
            elif key == 's' and mode != 'compact':
                message, anim_type = sleep_pet(state); message_time = time.time()
                if anim_type: anim_end = now + 1.5; anim_frames = ANIMATIONS[anim_type]; anim_idx = 0
                new_ach = check_achievements(state, pets_data)
                if new_ach: message = f'Achievement: {new_ach[0]}!'; message_time = time.time()
                save_state(uid, state, pets_data, pet_idx); need_redraw = True
            elif key == 'r' and mode != 'compact':
                bones = generate_companion(uid); name = generate_name(uid)
                state = init_state(uid, bones, name)
                pets_data['pets'][pet_idx] = state; save_pets(uid, pets_data)
                message = 'Regenerated!'; message_time = time.time()
                need_redraw = True
    finally:
        show_cursor(); clear_screen()
        print(f'\n  {render_face(bones)}  Bye!\n')

if __name__ == '__main__': main()
