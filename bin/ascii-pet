def layout_restore():
    global _window_pos
    sw, sh = get_screen_size()
    cols, rows = 50, 14
    px_w = cols * FONT_W + 20
    px_h = rows * FONT_H + 10
    if _window_pos:
        px, py = _clamp_pos(_window_pos[0], _window_pos[1], px_w, px_h, sw, sh)
    else:
        px = sw - px_w - 20
        py = sh - px_h - STATUS_BAR_HEIGHT
    set_window_geometry(cols, rows, px, py)

def do_layout(game):
    if game.mode == 'compact': layout_compact()
    elif game.mode == 'expanded': layout_expanded()
    elif game.mode == 'stats': layout_stats()
    elif game.mode == 'achievements': layout_achievements()
    elif game.mode == 'items': layout_items()
    elif game.mode == 'release': layout_release()
    elif game.mode == 'rename': layout_rename()
    elif game.mode == 'lan': layout_lan()
    elif game.mode == 'lan_name_edit': layout_lan_name_edit()

# ─── Main ─────────────────────────────────────────────────────────────────────

def main():
    global _window_pos
    uid = os.environ.get('USER', os.environ.get('USERNAME', 'anon'))
    if len(sys.argv) > 1:
        arg = sys.argv[1]
        if arg in ('--help','-h'):
            print('  ascii-pet — Terminal companion pet\n\n  Usage:\n    ascii-pet              Start pet\n    ascii-pet [username]   Specific username\n    ascii-pet --all        Show all species\n    ascii-pet --help       Help\n\n  Compact mode: just the pet\n  Expanded mode: full stats (Enter to toggle)\n  Commands: f feed, p play, s sleep, w adopt, b prev, n next, t stats, a achieve, e export, h help, c compact, m move, q quit')
            sys.exit(0)
        if arg == '--all':
            from ascii_pet.core import EVOLVED_BODIES
            all_species = SPECIES + list(EVOLVED_BODIES.keys())
            print(f'\n  All {len(all_species)} species:\n')
            for sp in all_species:
                fb = {'species':sp,'eye':'·','hat':'none','shiny':False,'stats':{},'rarity':'common'}
                print(f'  {sp}  {render_face(fb)}')
                for row in render_sprite(fb, 0): print(f'  {row}')
                print()
            sys.exit(0)
        uid = arg

    if sys.platform == 'win32':
        kernel32 = ctypes.windll.kernel32
        handle = kernel32.GetStdHandle(-11)
        mode = ctypes.c_uint32()
        if kernel32.GetConsoleMode(handle, ctypes.byref(mode)):
            mode.value |= 0x0004
            kernel32.SetConsoleMode(handle, mode)

    game = PetGame(uid)
    signal.signal(signal.SIGINT, lambda *_: (show_cursor(), clear_screen(), sys.exit(0)))

    clear_screen(); hide_cursor()
    layout_compact()

    prev_display = None; prev_mode = None; need_redraw = True
    last_tick = time.time()
    move_mode = False

    try:
        while True:
            now = time.time()

            if now - last_tick >= 0.5:
                msg, msg_time = game.tick()
                if msg: game.message = msg; game.message_time = msg_time
                game.process_lan_queues()
                last_tick = now; need_redraw = True

            if game.mode != prev_mode:
                cur = get_window_pos()
                if cur: _window_pos = cur
                do_layout(game)
                prev_mode = game.mode; need_redraw = True
                time.sleep(0.15)

            if need_redraw:
                if game.state.get('is_dead') and game.mode in ('compact', 'expanded'):
                    display = build_death(game)
                elif game.mode == 'compact': display = build_compact(game)
                elif game.mode == 'expanded': display = build_expanded(game)
                elif game.mode == 'stats': display = build_stats(game)
                elif game.mode == 'achievements': display = build_achievements(game)
                elif game.mode == 'items': display = build_items(game)
                elif game.mode == 'release': display = build_release(game)
                elif game.mode == 'rename': display = build_rename(game)
                if game.message and (game.warning_active or time.time() - game.message_time < 2):
                    display += f'\n  \033[33m{game.message}\033[0m'
                if move_mode:
                    display += '\n  \033[33m[MOVE] h← j↓ k↑ l→  m:exit\033[0m'
                if display != prev_display:
                    clear_screen()
                    print(display, end='', flush=True)
                    prev_display = display
                need_redraw = False

            if game.anim_end and now < game.anim_end:
                game.anim_idx = int((now * 6) % len(game.anim_frames))
                sys.stdout.write(f'\033[{len(display.splitlines())+1};1H\033[K')
                sys.stdout.write(f'  \033[33m{game.anim_frames[game.anim_idx]}\033[0m\n')
                sys.stdout.flush()
            elif game.anim_end and now >= game.anim_end:
                game.anim_end = 0; need_redraw = True

            key = get_key()
            if key is None: continue

            # Move mode toggle
            if key == 'm':
                move_mode = not move_mode
                need_redraw = True
                continue

            if move_mode:
                delta = 10
                cur = get_window_pos()
                sw, sh = get_screen_size()
                # Get actual window width/height from xdotool for clamping
                pw = ph = None
                wid = get_win_id()
                if wid:
                    try:
                        out = subprocess.check_output(['xdotool', 'getwindowgeometry', '--shell', wid], timeout=2).decode()
                        for line in out.splitlines():
                            if line.startswith('WIDTH='): pw = int(line.split('=')[1])
                            elif line.startswith('HEIGHT='): ph = int(line.split('=')[1])
                    except: pass
                if pw is None: pw = 18 * FONT_W + 8
                if ph is None: ph = 8 * FONT_H + 4
                if key == 'h':
                    if cur: _window_pos = (max(0, cur[0] - delta), cur[1])
                elif key == 'j':
                    if cur: _window_pos = (cur[0], min(sh - ph, cur[1] + delta))
                elif key == 'k':
                    if cur: _window_pos = (cur[0], max(0, cur[1] - delta))
                elif key == 'l':
                    if cur: _window_pos = (min(sw - pw, cur[0] + delta), cur[1])
                else:
                    move_mode = False
                    need_redraw = True
                    atype, detail = game.handle_key(key)
                    if atype == 'quit': break
                    elif atype == 'mode_change':
                        cur = get_window_pos()
                        if cur: _window_pos = cur
                        do_layout(game)
                        prev_mode = game.mode; need_redraw = True
                        time.sleep(0.15)
                    elif atype == 'export':
                        text = export_text(game.state, game.bones, game.frame_idx)
                        cmds = [['xclip','-selection','clipboard'],['xsel','--clipboard','--input']]
                        if sys.platform == 'win32': cmds = [['clip.exe']]
                        copied = False
                        for cmd in cmds:
                            try:
                                p = subprocess.Popen(cmd, stdin=subprocess.PIPE)
                                p.communicate(text.encode())
                                copied = True; break
                            except: pass
                        game.message = 'Copied to clipboard!' if copied else 'Printed to terminal'
                        game.message_time = time.time(); need_redraw = True
                    elif atype in ('action', 'pet_switch'):
                        need_redraw = True
                    continue

                if cur:
                    px, py = _clamp_pos(_window_pos[0], _window_pos[1], pw, ph, sw, sh)
                    _window_pos = (px, py)
                    wid = get_win_id()
                    if wid:
                        subprocess.run(['xdotool', 'windowmove', wid, str(px), str(py)], timeout=1)
                continue

            # Direction keys: left/right arrows switch pets
            if key == '\x1b[D' or key == '\x1b[C':
                # Left arrow = previous pet (b), right arrow = next pet (n)
                arrow_key = 'b' if key == '\x1b[D' else 'n'
                atype, detail = game.handle_key(arrow_key)
                if atype == 'pet_switch':
                    need_redraw = True
                continue

            atype, detail = game.handle_key(key)
            if atype == 'quit': break
            elif atype == 'mode_change':
                cur = get_window_pos()
                if cur: _window_pos = cur
                do_layout(game)
                prev_mode = game.mode; need_redraw = True
                time.sleep(0.15)
            elif atype == 'export':
                text = export_text(game.state, game.bones, game.frame_idx)
                cmds = [['xclip','-selection','clipboard'],['xsel','--clipboard','--input']]
                if sys.platform == 'win32': cmds = [['clip.exe']]
                copied = False
                for cmd in cmds:
                    try:
                        p = subprocess.Popen(cmd, stdin=subprocess.PIPE)
                        p.communicate(text.encode())
                        copied = True; break
                    except: pass
                game.message = 'Copied to clipboard!' if copied else 'Printed to terminal'
                game.message_time = time.time(); need_redraw = True
            elif atype in ('action', 'pet_switch'):
                need_redraw = True
    finally:
        try:
            game.disable_lan()
        except Exception:
            pass
        show_cursor(); clear_screen()
        print(f'\n  {render_face(game.bones)}  Bye!\n')

if __name__ == '__main__': main()
