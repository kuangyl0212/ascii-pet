#!/usr/bin/env python3
"""ASCII Desktop Pet - Terminal Companion (Linux)"""

import os, sys, signal, subprocess, select, time

# Add src/ to path so ascii_pet package is importable when run directly
from pathlib import Path
_src = Path(__file__).resolve().parent.parent / 'src'
if str(_src) not in sys.path:
    sys.path.insert(0, str(_src))

if sys.platform == 'win32':
    import msvcrt, ctypes
else:
    import termios, tty

from ascii_pet.core import (
    SPECIES, RARITY_STARS, STAT_NAMES, MOODS, ANIMATIONS, ACHIEVEMENTS, MAX_PETS,
    THEMES, DEFAULT_THEME,
    render_sprite, render_face, render_frame, export_text,
    PetGame,
)
from ascii_pet.i18n import _, get_language, set_language, save_settings
from ascii_pet.i18n import get_theme, set_theme, save_theme, init_theme

# ─── ANSI colors ──────────────────────────────────────────────────────────────

RARITY_COLORS = {'common':'\033[90m','uncommon':'\033[32m','rare':'\033[36m','epic':'\033[35m','legendary':'\033[33m'}
MOOD_COLORS = {'happy':'\033[33m','normal':'\033[0m','sleepy':'\033[90m','hungry':'\033[31m','excited':'\033[35m'}

# ─── Theme-driven colors (refreshed by _refresh_theme) ───────────────────────

COLOR_DIM = '\033[2m'
COLOR_MSG = '\033[33m'
COLOR_WHITE = '\033[37m'
COLOR_BAR_FILL = '\033[32m'
COLOR_BAR_EMPTY = '\033[90m'


def _refresh_theme():
    """Update module-level color vars from current theme.

    Reads ansi_dim, ansi_white, ansi_bar_fill from THEMES[get_theme()].
    Called on startup and after theme switching.
    """
    global COLOR_DIM, COLOR_MSG, COLOR_WHITE, COLOR_BAR_FILL, COLOR_BAR_EMPTY
    theme_name = get_theme()
    t = THEMES.get(theme_name, THEMES[DEFAULT_THEME])
    COLOR_DIM = t.get('ansi_dim', '\033[2m')
    COLOR_WHITE = t.get('ansi_white', '\033[37m')
    COLOR_BAR_FILL = t.get('ansi_bar_fill', '\033[32m')
    COLOR_MSG = t.get('ansi_msg', '\033[33m')
    COLOR_BAR_EMPTY = t.get('ansi_bar_empty', '\033[90m')

# ─── Window control via xdotool ───────────────────────────────────────────────

FONT_W = 8
FONT_H = 17
STATUS_BAR_HEIGHT = 30
_window_pos = None

def get_win_id():
    if sys.platform == 'win32':
        return ctypes.windll.kernel32.GetConsoleWindow()
    for _ in range(5):
        try:
            out = subprocess.check_output(['xdotool','search','--class','ascii-pet'], timeout=2).decode().strip()
            if out: return out.split('\n')[0]
        except: pass
        time.sleep(0.2)
    return None

def set_window_geometry(cols, rows, pos_x, pos_y):
    if sys.platform == 'win32':
        hwnd = ctypes.windll.kernel32.GetConsoleWindow()
        if not hwnd: return
        px_w = cols * FONT_W + 20
        px_h = rows * FONT_H + 10
        ctypes.windll.user32.MoveWindow(hwnd, pos_x, pos_y, px_w, px_h, True)
        return
    wid = get_win_id()
    if not wid: return
    px_w = cols * FONT_W + 20
    px_h = rows * FONT_H + 10
    try:
        subprocess.run(['xdotool','windowsize',wid,str(px_w),str(px_h)], timeout=2)
        subprocess.run(['xdotool','windowmove',wid,str(pos_x),str(pos_y)], timeout=2)
    except: pass

def get_screen_size():
    if sys.platform == 'win32':
        user32 = ctypes.windll.user32
        return user32.GetSystemMetrics(0), user32.GetSystemMetrics(1)
    try:
        out = subprocess.check_output(['xdotool','getdisplaygeometry'], timeout=2).decode().strip().split()
        return int(out[0]), int(out[1])
    except: return 1920, 1080

def get_window_pos():
    if sys.platform == 'win32':
        hwnd = ctypes.windll.kernel32.GetConsoleWindow()
        if not hwnd: return None
        from ctypes import wintypes, byref
        rect = wintypes.RECT()
        ctypes.windll.user32.GetWindowRect(hwnd, byref(rect))
        return rect.left, rect.top
    wid = get_win_id()
    if not wid: return None
    try:
        out = subprocess.check_output(['xdotool', 'getwindowgeometry', '--shell', wid], timeout=2).decode().strip()
        x, y = None, None
        for line in out.splitlines():
            if line.startswith('X='): x = int(line.split('=')[1])
            elif line.startswith('Y='): y = int(line.split('=')[1])
        if x is not None and y is not None: return x, y
    except: pass
    return None

def _clamp_pos(px, py, pw, ph, sw, sh):
    return max(0, min(px, sw - pw)), max(0, min(py, sh - ph))

# ─── Terminal ─────────────────────────────────────────────────────────────────

def clear_screen(): sys.stdout.write('\033[2J\033[H'); sys.stdout.flush()
def hide_cursor(): sys.stdout.write('\033[?25l'); sys.stdout.flush()
def show_cursor(): sys.stdout.write('\033[?25h'); sys.stdout.flush()

def get_key():
    if sys.platform == 'win32':
        if msvcrt.kbhit():
            b = msvcrt.getch()
            try: return b.decode('utf-8', errors='replace')
            except: return None
        return None
    fd = sys.stdin.fileno()
    try: old = termios.tcgetattr(fd)
    except: return None
    try:
        tty.setraw(fd)
        dr,_,_ = select.select([sys.stdin],[],[],0.1)
        return sys.stdin.read(1) if dr else None
    finally:
        try: termios.tcsetattr(fd, termios.TCSADRAIN, old)
        except: pass

# ─── ANSI rendering ───────────────────────────────────────────────────────────

def stat_bar(value, width=15):
    filled = round((value / 100) * width)
    return '\033[90m\033[32m' + '█'*filled + '\033[90m' + '░'*(width-filled) + '\033[0m'

def build_compact(game):
    lines = render_frame(game.bones, game.frame_idx, game.state.get('mood','normal'))
    return '\n'.join(lines)

def build_expanded(game):
    RST='\033[0m'; DIM='\033[2m'; BOLD='\033[1m'
    color = RARITY_COLORS[game.state['rarity']]; stars = RARITY_STARS[game.state['rarity']]
    shiny = f' {BOLD}\033[33mSHINY{RST}' if game.state['shiny'] else ''
    mood = MOODS[game.state['mood']]
    frame = render_frame(game.bones, game.frame_idx, game.state.get('mood','normal'))

    lines = []
    lines.append(f'{color}{BOLD}{game.state["name"]}{RST} {color}{stars}{RST}{shiny}')
    lines.append(f'{DIM}{game.state["species"]}·{game.state["rarity"]}{RST} {MOOD_COLORS[game.state["mood"]]}[{mood["emoji"]}]{RST}')
    lines.append(f'{DIM}Lv.{game.state["level"]} XP:{game.state["xp"]}/{game.state["level"]*100}{RST}')
    if game.state.get('evolved'):
        lines.append(f'{DIM}★ Evolved{RST}')
    try:
        from ascii_pet.weather import format_weather_line
        weather_line = format_weather_line(game.state.get('weather'))
        if weather_line:
            lines.append(f'{DIM}{weather_line}{RST}')
    except ImportError:
        pass
    for row in frame: lines.append(f' {row}')
    for s in STAT_NAMES:
        v = game.state['stats'][s]
        lines.append(f'{DIM}{s[:4]}{RST}{stat_bar(v,15)}{v}')
    if game.show_help:
        lines.append(f'{DIM}[f]feed [p]play [s]sleep [w]adopt [b]prev [n]next [t]stats [a]achieve [u]items [e]export [m]move [Enter]compact [q]quit{RST}')
    return '\n'.join(lines)

def build_stats(game):
    RST='\033[0m'; DIM='\033[2m'; BOLD='\033[1m'
    color = RARITY_COLORS[game.state['rarity']]
    frame = render_frame(game.bones, game.frame_idx, game.state.get('mood','normal'))
    from datetime import datetime
    created = datetime.fromisoformat(game.state['created_at'])
    days = (datetime.now() - created).days
    hours = (datetime.now() - created).total_seconds() / 3600
    evo = ' ★Evolved' if game.state.get('evolved') else ''

    lines = [f'{BOLD}Stats for {game.state["name"]}{RST}']
    lines.append(f'{DIM}Species:{RST} {game.state["species"]}')
    lines.append(f'{DIM}Face:{RST} {render_face(game.bones)}')
    lines.append(f'{DIM}Eye:{RST} {game.state["eye"]}')
    lines.append(f'{DIM}Hat:{RST} {game.state["hat"]}')
    lines.append(f'{DIM}Pet:{RST} {game.pet_idx+1}/{len(game.pets_data["pets"])}{evo}')
    lines.append('')
    for row in frame: lines.append(f' {row}')
    lines.append('')
    lines.append(f'{DIM}--- Activity ---{RST}')
    lines.append(f'  {DIM}Days adopted:{RST}  {days}')
    lines.append(f'  {DIM}Hours online:{RST} {hours:.1f}')
    lines.append(f'  {DIM}Feed count:{RST}   {game.state.get("feed_count",0)}')
    lines.append(f'  {DIM}Play count:{RST}   {game.state.get("play_count",0)}')
    lines.append(f'  {DIM}Sleep count:{RST}  {game.state.get("sleep_count",0)}')
    lines.append(f'  {DIM}Total acts:{RST}   {game.state["total_interactions"]}')
    lines.append('')
    lines.append(f'{DIM}--- Growth ---{RST}')
    lines.append(f'  {DIM}Level:{RST} {game.state["level"]}  {DIM}XP:{RST} {game.state["xp"]}/{game.state["level"]*100}')
    lines.append(f'  {DIM}Rarity:{RST} {game.state["rarity"]}  {DIM}Shiny:{RST} {"Yes" if game.state["shiny"] else "No"}')
    lines.append(f'{DIM}[r]rename [Enter]back{RST}')
    return '\n'.join(lines)

def build_achievements(game):
    RST='\033[0m'; DIM='\033[2m'; BOLD='\033[1m'
    unlocked = game.state.get('achievements', [])
    lines = [f'{BOLD}Achievements for {game.state["name"]}{RST}']
    lines.append(f'{DIM}{len(unlocked)}/{len(ACHIEVEMENTS)} unlocked{RST}')
    lines.append('')
    for aid, ach in ACHIEVEMENTS.items():
        if aid in unlocked:
            lines.append(f'  {ach["icon"]} {BOLD}{ach["name"]}{RST}')
        else:
            lines.append(f'  {DIM}??? Locked{RST}')
    return '\n'.join(lines)

def build_items(game):
    from ascii_pet.core import ITEMS, MAX_INVENTORY
    RST='\033[0m'; DIM='\033[2m'; BOLD='\033[1m'
    inv_list = game.get_inventory_list()
    total = sum(game.pets_data.get('inventory', {}).values())
    lines = [f'{BOLD}Inventory{RST} ({total}/{MAX_INVENTORY})']
    lines.append(f'{DIM}Select item [1-7] or [c]cancel{RST}')
    lines.append('')
    if not inv_list:
        lines.append(f'{DIM}  Empty — items drop from random events{RST}')
    else:
        for i, (iid, name, icon, count, desc) in enumerate(inv_list):
            lines.append(f'  {BOLD}{i+1}{RST}  {icon} {name} x{count}  {DIM}{desc}{RST}')
    return '\n'.join(lines)

def build_release(game):
    RST='\033[0m'; DIM='\033[2m'; BOLD='\033[1m'
    pets = game.get_release_list()
    lines = [f'{BOLD}\033[31mSelect a pet to release:{RST}']
    lines.append(f'{DIM}Max {MAX_PETS} pets. Choose 1-3, or [c]cancel{RST}')
    lines.append('')
    for idx, name, species, rarity in pets:
        color = RARITY_COLORS[rarity]
        stars = RARITY_STARS[rarity]
        lines.append(f'  {BOLD}{idx}{RST}  {color}{name}{RST} {DIM}{species}·{rarity}{RST} {color}{stars}{RST}')
    lines.append('')
    lines.append(f'{DIM}[1-3]select [c]cancel{RST}')
    return '\n'.join(lines)

def build_death(game):
    RST='\033[0m'; BOLD='\033[1m'; RED='\033[31m'; DIM='\033[90m'
    frame = render_frame(game.bones, game.frame_idx, 'normal')
    potion_count = game.pets_data.get('inventory', {}).get('potion', 0)
    revive_color = RED if potion_count > 0 else DIM
    lines = [f'{RED}{BOLD}  Your pet has died...{RST}']
    lines.append('')
    for row in frame:
        lines.append(f'  {DIM}{row}{RST}')
    lines.append('')
    lines.append(f'{revive_color}  [r]revive (Potion x{potion_count}){RST}')
    lines.append(f'{RED}  [d]release{RST}')
    lines.append(f'{DIM}[u]backpack{RST}')
    return '\n'.join(lines)

def build_rename(game):
    RST='\033[0m'; DIM='\033[2m'; WHITE='\033[37m'
    color = RARITY_COLORS.get(game.state['rarity'], '')
    lines = []
    lines.append(f'{color}═ Rename Pet ═{RST}')
    lines.append('')
    lines.append(f'{DIM}Current name: {game.state["name"]}{RST}')
    lines.append(f'{WHITE}New name: {game._rename_input}_{RST}')
    lines.append('')
    lines.append(f'{DIM}[Enter]confirm [ESC]cancel [Backspace]delete{RST}')
    return '\n'.join(lines)

def build_lan_panel(game):
    """Render community plaza panel. Returns ANSI string."""
    RST = '\033[0m'
    DIM = COLOR_DIM
    MSG = COLOR_MSG
    WHITE = COLOR_WHITE
    BAR_FILL = COLOR_BAR_FILL
    BAR_EMPTY = COLOR_BAR_EMPTY

    lines = []
    status = game.get_lan_status()
    enabled = status.get('enabled', False)

    lines.append(f'{MSG}═ {_("Community Plaza")} ═{RST}')
    if enabled:
        peer_count = status.get('peer_count', 0)
        lines.append(f'{BAR_FILL}{_("Username: {}  |  Players online: {}").format(game.lan_username or "?", peer_count)}{RST}')
        pet_name = game.state.get('name', '?')
        species = game.state.get('species', '?')
        level = game.state.get('level', 1)
        hp = game.state.get('hp', 100)
        lines.append(f'{DIM}{pet_name} | {species} | Lv.{level} | HP:{hp}/100{RST}')
    else:
        lines.append(f'{BAR_EMPTY}{_("Status: Disconnected")}{RST}')
        error = status.get('error')
        if error:
            lines.append(f'{BAR_EMPTY}{_("Error: {}").format(error)}{RST}')
    lines.append('')

    # Visit status
    if game.active_visit:
        elapsed = int(time.time() - game.active_visit.get('start_time', 0))
        minutes, seconds = divmod(elapsed, 60)
        lines.append(f'{MSG}{_("★ Visiting ({}m{}s)").format(minutes, seconds)}{RST}')
        lines.append('')
    if game.being_visited:
        elapsed = int(time.time() - game.being_visited.get('start_time', 0))
        minutes, seconds = divmod(elapsed, 60)
        visitor_name = game.being_visited.get('pet_snapshot', {}).get('name', '?')
        lines.append(f'{MSG}{_("★ {} is visiting you ({}m{}s)").format(visitor_name, minutes, seconds)}{RST}')
        lines.append('')

    # Game message (within 10s)
    if game.message and time.time() - getattr(game, 'message_time', 0) < 10:
        lines.append(f'  {MSG}{game.message}{RST}')
        lines.append('')

    # Peer list (paginated)
    all_peers = game.get_lan_peers() if enabled else []
    if enabled:
        peers_page, total_pages, cur_page = game.get_lan_peers_page()
    else:
        peers_page, total_pages, cur_page = [], 0, 0
    if all_peers:
        lines.append(f'{DIM}{_("─ Online Players (Page {}/{}) ─").format(cur_page + 1, total_pages)}{RST}')
        for i, peer in enumerate(peers_page):
            username = peer.get('username', '?')
            pet = peer.get('pet_summary', {})
            pet_name = pet.get('name', '?')
            species = pet.get('species', '?')
            lines.append(f'{WHITE}[{i+1}] {username} - {pet_name}({species}){RST}')
    else:
        lines.append(f'{DIM}{_("(No other players)")}{RST}')
    lines.append('')

    # Visitor list
    visitors = game.visitor_pets
    if visitors:
        lines.append(f'{DIM}{_("─ Visitors ─")}{RST}')
        for v in visitors.values():
            lines.append(f'{WHITE}  {v.get("name","?")}({v.get("species","?")}){RST}')

    # Actions section
    lines.append(f'{DIM}{_("─ Actions ─")}{RST}')
    if enabled:
        submode = game.lan_submode
        if submode == 'visit':
            lines.append(f'{MSG}{_("Select visit target:")}{RST}')
            for i, peer in enumerate(all_peers[:9]):
                username = peer.get('username', '?')
                pet = peer.get('pet_summary', {})
                lines.append(f'{WHITE}[{i+1}] {username} - {pet.get("name","?")}({pet.get("species","?")}){RST}')
            lines.append(f'{DIM}{_("[ESC]Cancel")}{RST}')
        elif submode == 'challenge':
            lines.append(f'{MSG}{_("Select challenge target:")}{RST}')
            for i, peer in enumerate(all_peers[:9]):
                username = peer.get('username', '?')
                pet = peer.get('pet_summary', {})
                lines.append(f'{WHITE}[{i+1}] {username} - {pet.get("name","?")}({pet.get("species","?")}){RST}')
            lines.append(f'{DIM}{_("[ESC]Cancel")}{RST}')
        elif submode == 'gift':
            lines.append(f'{MSG}{_("Select gift target:")}{RST}')
            for i, peer in enumerate(all_peers[:9]):
                username = peer.get('username', '?')
                pet = peer.get('pet_summary', {})
                lines.append(f'{WHITE}[{i+1}] {username} - {pet.get("name","?")}({pet.get("species","?")}){RST}')
            lines.append(f'{DIM}{_("[ESC]Cancel")}{RST}')
        elif submode == 'gift_item':
            lines.append(f'{MSG}{_("Select item to gift:")}{RST}')
            inv_list = game.get_inventory_list()
            for i, (item_id, name, icon, cnt, desc) in enumerate(inv_list[:9]):
                lines.append(f'{WHITE}[{i+1}] {icon} {name} x{cnt}{RST}')
            lines.append(f'{DIM}{_("[ESC]Cancel")}{RST}')
        elif submode == 'trade':
            lines.append(f'{MSG}{_("Select trade target:")}{RST}')
            for i, peer in enumerate(all_peers[:9]):
                username = peer.get('username', '?')
                pet = peer.get('pet_summary', {})
                lines.append(f'{WHITE}[{i+1}] {username} - {pet.get("name","?")}({pet.get("species","?")}){RST}')
            lines.append(f'{DIM}{_("[ESC]Cancel")}{RST}')
        elif submode == 'trade_pet':
            lines.append(f'{MSG}{_("Select pet to trade:")}{RST}')
            pets = game.pets_data.get('pets', [])
            for i, pet in enumerate(pets[:9]):
                lines.append(f'{WHITE}[{i+1}] {pet.get("name","?")} - {pet.get("species","?")}(Lv.{pet.get("level",1)}){RST}')
            lines.append(f'{DIM}{_("[ESC]Cancel")}{RST}')
        elif game.active_visit or game.being_visited:
            lines.append(f'{DIM}{_("[e]End Visit [f]Remote Feed [p]Remote Play")}{RST}')
        else:
            lines.append(f'{DIM}{_("[u]Edit Username")}{RST}')
        # Action hints when idle
        if submode is None:
            if game.active_challenge:
                lines.append(f'{MSG}{_("★ Challenge in progress...")}{RST}')
            elif game.active_gift:
                lines.append(f'{MSG}{_("★ Gifting... (timeout 10s)")}{RST}')
            elif game.active_trade:
                lines.append(f'{MSG}{_("★ Trading... (timeout 30s)")}{RST}')
            elif all_peers:
                lines.append(f'{DIM}{_("[v]Visit [c]Challenge [g]Gift [t]Trade [h]Heal")}{RST}')
        # Trade confirmation
        if game.pending_trade_req is not None:
            if game.pending_trade_req.get('_accepting'):
                lines.append(f'{MSG}{_("Select pet to trade:")}{RST}')
                pets = game.pets_data.get('pets', [])
                for i, pet in enumerate(pets[:9]):
                    lines.append(f'{WHITE}[{i+1}] {pet.get("name","?")} - {pet.get("species","?")}(Lv.{pet.get("level",1)}){RST}')
                lines.append(f'{DIM}{_("[ESC]Cancel")}{RST}')
            else:
                from_username = game.pending_trade_req.get('from_username', '?')
                pet_name = game.pending_trade_req.get('pet_snapshot', {}).get('name', '?')
                lines.append(f'{MSG}{_("{} wants to trade {}! [y]Accept [n]Reject").format(from_username, pet_name)}{RST}')
        if total_pages >= 2:
            lines.append(f'{DIM}{_("Prev Page: [  Next Page: ]")}{RST}')
        lines.append(f'{DIM}{_("[l]Back [o]Disable LAN")}{RST}')
    else:
        lines.append(f'{DIM}{_("[o]Enable LAN")}{RST}')
    lines.append(f'{DIM}{_("[l]Back")}{RST}')

    return '\n'.join(lines)

# ─── Layout ───────────────────────────────────────────────────────────────────

def layout_compact():
    global _window_pos
    sw, sh = get_screen_size()
    cols, rows = 18, 8
    px_w = cols * FONT_W + 8
    px_h = rows * FONT_H + 4
    if _window_pos:
        px, py = _clamp_pos(_window_pos[0], _window_pos[1], px_w, px_h, sw, sh)
    else:
        px = sw - px_w - 10
        py = sh - px_h - STATUS_BAR_HEIGHT
    set_window_geometry(cols, rows, px, py)

def layout_expanded():
    global _window_pos
    sw, sh = get_screen_size()
    cols, rows = 36, 26
    px_w = cols * FONT_W + 20
    px_h = rows * FONT_H + 10
    if _window_pos:
        px, py = _clamp_pos(_window_pos[0], _window_pos[1], px_w, px_h, sw, sh)
    else:
        px = sw - px_w - 20
        py = sh - px_h - STATUS_BAR_HEIGHT
    set_window_geometry(cols, rows, px, py)

def layout_stats():
    global _window_pos
    sw, sh = get_screen_size()
    cols, rows = 42, 24
    px_w = cols * FONT_W + 20
    px_h = rows * FONT_H + 10
    if _window_pos:
        px, py = _clamp_pos(_window_pos[0], _window_pos[1], px_w, px_h, sw, sh)
    else:
        px = sw - px_w - 20
        py = sh - px_h - STATUS_BAR_HEIGHT
    set_window_geometry(cols, rows, px, py)

def layout_achievements():
    global _window_pos
    sw, sh = get_screen_size()
    cols, rows = 42, 22
    px_w = cols * FONT_W + 20
    px_h = rows * FONT_H + 10
    if _window_pos:
        px, py = _clamp_pos(_window_pos[0], _window_pos[1], px_w, px_h, sw, sh)
    else:
        px = sw - px_w - 20
        py = sh - px_h - STATUS_BAR_HEIGHT
    set_window_geometry(cols, rows, px, py)

def layout_items():
    global _window_pos
    sw, sh = get_screen_size()
    cols, rows = 42, 16
    px_w = cols * FONT_W + 20
    px_h = rows * FONT_H + 10
    if _window_pos:
        px, py = _clamp_pos(_window_pos[0], _window_pos[1], px_w, px_h, sw, sh)
    else:
        px = sw - px_w - 20
        py = sh - px_h - STATUS_BAR_HEIGHT
    set_window_geometry(cols, rows, px, py)

def layout_release():
    global _window_pos
    sw, sh = get_screen_size()
    cols, rows = 42, 14
    px_w = cols * FONT_W + 20
    px_h = rows * FONT_H + 10
    if _window_pos:
        px, py = _clamp_pos(_window_pos[0], _window_pos[1], px_w, px_h, sw, sh)
    else:
        px = sw - px_w - 20
        py = sh - px_h - STATUS_BAR_HEIGHT
    set_window_geometry(cols, rows, px, py)

def layout_lan():
    global _window_pos
    sw, sh = get_screen_size()
    cols, rows = 50, 20
    px_w = cols * FONT_W + 20
    px_h = rows * FONT_H + 10
    if _window_pos:
        px, py = _clamp_pos(_window_pos[0], _window_pos[1], px_w, px_h, sw, sh)
    else:
        px = sw - px_w - 20
        py = sh - px_h - STATUS_BAR_HEIGHT
    set_window_geometry(cols, rows, px, py)

